{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agent-homebase/schemas/subagent-return-tier2.schema.json",
  "title": "Subagent Return Schema - Tier 2 (Artifact Creation)",
  "description": "Schema for subagent returns that create file artifacts",
  "type": "object",
  "required": ["tier", "agent", "status", "summary", "findings", "artifactPath", "artifactType"],
  "properties": {
    "tier": {
      "type": "integer",
      "const": 2,
      "description": "Return tier identifier"
    },
    "agent": {
      "type": "string",
      "minLength": 1,
      "description": "Agent name",
      "examples": ["planner", "pm", "architect", "researcher"]
    },
    "status": {
      "type": "string",
      "enum": ["complete", "blocked", "needs-input"],
      "description": "Execution status"
    },
    "summary": {
      "type": "string",
      "minLength": 10,
      "maxLength": 500,
      "description": "1-2 sentence result summary"
    },
    "artifactPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^/].*\\.(md|json|yml|yaml)$",
      "description": "Relative path to created artifact (must not start with /)",
      "examples": [
        "docs/planning/drafts/feature-x-brainstorm.md",
        "docs/research/api-comparison.md"
      ]
    },
    "artifactType": {
      "type": "string",
      "enum": ["brainstorm", "draft-plan", "validation", "research", "architecture"],
      "description": "Category of artifact matching the write permit"
    },
    "findings": {
      "type": "array",
      "description": "Array of findings (may be empty)",
      "items": {
        "type": "object",
        "required": ["severity", "description", "recommendation"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["CRITICAL", "WARNING", "SUGGESTION"]
          },
          "description": {
            "type": "string",
            "minLength": 5
          },
          "recommendation": {
            "type": "string",
            "minLength": 5
          }
        },
        "additionalProperties": false
      }
    },
    "flaggedDecisions": {
      "type": "array",
      "description": "Decisions requiring human confirmation",
      "items": {
        "type": "string",
        "minLength": 5
      }
    },
    "blockerReason": {
      "type": "string",
      "minLength": 5,
      "description": "Reason for blockage (required if status=blocked)"
    }
  },
  "additionalProperties": false,
  "if": {
    "properties": {
      "status": {
        "const": "blocked"
      }
    }
  },
  "then": {
    "required": ["blockerReason"]
  }
}
