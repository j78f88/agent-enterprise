{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agent-homebase/schemas/project-v1.schema.json",
  "title": "Project Registry Entry — v1",
  "description": "Shape of a single project entry in a Mode-3 choreography registry. Implements command-centre/01-protocols/project-contract.md (contract tag: project-contract-v1).",
  "type": "object",
  "required": ["id", "name", "repo", "mode_level", "substrate_version", "contract_pins"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "description": "Unique within the registry."
    },
    "name": { "type": "string", "minLength": 1 },
    "repo": {
      "type": "string",
      "pattern": "^(https://|ssh://|git@|local:).+",
      "description": "https://, ssh://, git@, or local:./path"
    },
    "mode_level": {
      "type": "string",
      "enum": ["team", "orchestration"],
      "description": "team = Mode 1; orchestration = Mode 1 + Mode 2."
    },
    "substrate_version": {
      "type": "string",
      "description": "agent-homebase semver, or the literal string 'custom'."
    },
    "contract_pins": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*-v\\d+$" },
      "minItems": 1
    },
    "description": { "type": "string" },
    "owner": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "last_harvested_at": { "type": "string", "format": "date-time" },
    "custom_substrate": {
      "type": "object",
      "required": ["provider", "provider_version"],
      "properties": {
        "provider": { "type": "string" },
        "provider_version": { "type": "string" }
      },
      "additionalProperties": true
    },
    "dispatcher": {
      "type": "object",
      "required": ["impl", "impl_version"],
      "properties": {
        "impl": { "type": "string" },
        "impl_version": { "type": "string" },
        "queue_source": { "type": "string" }
      },
      "additionalProperties": true
    },
    "notes": { "type": "string" }
  },
  "allOf": [
    {
      "if": { "properties": { "substrate_version": { "const": "custom" } } },
      "then": { "required": ["custom_substrate"] }
    },
    {
      "if": { "properties": { "mode_level": { "const": "orchestration" } } },
      "then": { "required": ["dispatcher"] }
    }
  ],
  "additionalProperties": false
}
