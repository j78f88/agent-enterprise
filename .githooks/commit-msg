#!/usr/bin/env bash
# Reject commit messages that:
#   1. Start with a UTF-8 BOM (EF BB BF).
#   2. Do not start with a Conventional Commits prefix.
#
# Install once per clone:
#   git config core.hooksPath .githooks
#
# Bypass (use sparingly, e.g. merge commits):
#   git commit --no-verify ...

set -eu

msg_file="${1:?missing commit message file path}"

# 1. BOM check: read first 3 bytes.
first_bytes=$(head -c 3 "$msg_file" | od -An -tx1 | tr -d ' \n')
if [ "$first_bytes" = "efbbbf" ]; then
  echo "commit-msg: rejected — message starts with a UTF-8 BOM."
  echo "  Cause: the editor or shell wrote the message file as UTF-8-with-BOM."
  echo "  Fix:   on Windows, configure your editor to save without BOM, or"
  echo "         commit with: git commit -m \"...\"  (avoids file roundtrip)."
  exit 1
fi

# 2. Conventional Commits prefix check.
first_line=$(head -n1 "$msg_file")

# Allow merge commits and revert commits unconditionally.
case "$first_line" in
  "Merge "*|"Revert "*) exit 0 ;;
esac

# Strip an optional leading BOM that survived (shouldn't, given step 1)
# and any leading whitespace before the type token.
first_line_stripped=$(printf '%s' "$first_line" | sed 's/^[[:space:]]*//')

# Pattern: type(optional-scope)!?: subject
pattern='^(feat|fix|chore|docs|refactor|test|perf|build|ci|style|revert)(\([a-z0-9._/-]+\))?!?: .+'
if ! printf '%s' "$first_line_stripped" | grep -Eq "$pattern"; then
  echo "commit-msg: rejected — first line does not match Conventional Commits."
  echo "  Got:      $first_line_stripped"
  echo "  Expected: <type>(<scope>)?: <subject>"
  echo "  Types:    feat fix chore docs refactor test perf build ci style revert"
  echo "  Example:  feat(schemas): add registry-v1"
  exit 1
fi

exit 0
